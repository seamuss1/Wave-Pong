{
  "name": "wave-pong-tools",
  "private": true,
  "version": "1.0.0",
  "description": "Tooling for the Wave Pong repo",
  "scripts": {
    "build:itch": "node build-itch-html.js",
    "build:zip": "powershell -ExecutionPolicy Bypass -File ./build-itch-zip.ps1",
    "deploy:test": "powershell -ExecutionPolicy Bypass -File ./deploy-itch.ps1 -Destination test",
    "deploy:production": "powershell -ExecutionPolicy Bypass -File ./deploy-itch.ps1 -Destination production",
    "smoke": "powershell -ExecutionPolicy Bypass -File ./browser-smoke-test.ps1",
    "smoke:node": "node browser-smoke-test.js",
    "version:patch": "powershell -ExecutionPolicy Bypass -File ./bump-version.ps1 -Level patch",
    "version:minor": "powershell -ExecutionPolicy Bypass -File ./bump-version.ps1 -Level minor",
    "version:major": "powershell -ExecutionPolicy Bypass -File ./bump-version.ps1 -Level major"
  }
}
