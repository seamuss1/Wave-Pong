# Wave Pong online-play configuration (backend/server.js reads this via env-loader)

WAVE_PONG_SECRET=change-me

# Ports for the two listeners inside the single backend process
WAVE_PONG_CONTROL_PORT=8787
WAVE_PONG_WORKER_PORT=8788

# Public URLs the browser client should use to reach this host
WAVE_PONG_PUBLIC_API_BASE_URL=http://127.0.0.1:8787
WAVE_PONG_PUBLIC_CONTROL_WS_URL=ws://127.0.0.1:8787/ws/control
WAVE_PONG_PUBLIC_WORKER_WS_URL=ws://127.0.0.1:8788/ws/match
WAVE_PONG_ONLINE_ENABLED=true
