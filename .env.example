# Wave Pong local + cloud-shaped configuration

NODE_ENV=development
WAVE_PONG_ENVIRONMENT=development
WAVE_PONG_SECRET=wave-pong-local-secret

# Local ports/hosts for the backend processes
WAVE_PONG_CONTROL_HOST=127.0.0.1
WAVE_PONG_CONTROL_PORT=8787
WAVE_PONG_WORKER_HOST=127.0.0.1
WAVE_PONG_WORKER_PORT=8788

# Public URLs that the static browser client should use
WAVE_PONG_PUBLIC_API_BASE_URL=http://127.0.0.1:8787
WAVE_PONG_PUBLIC_CONTROL_WS_URL=ws://127.0.0.1:8787/ws/control
WAVE_PONG_PUBLIC_WORKER_WS_URL=ws://127.0.0.1:8788/ws/match
WAVE_PONG_STATIC_CLIENT_ORIGIN=http://127.0.0.1:8080
WAVE_PONG_ONLINE_ENABLED=true

# Internal service wiring for split deployments
WAVE_PONG_INTERNAL_WORKER_WS_URL=ws://127.0.0.1:8788/ws/match

# Durable services
DATABASE_URL=postgres://wavepong:wavepong@127.0.0.1:5432/wave_pong
REDIS_URL=redis://127.0.0.1:6379
